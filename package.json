{
  "name": "trading_platform",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "compose:up": "docker compose -f docker/docker-compose.yaml up -d --build",
    "compose:down": "docker compose -f docker/docker-compose.yaml down -v",
    "compose:logs": "docker compose -f docker/docker-compose.yaml logs -f backend",
    "compose:exec": "docker compose -f docker/docker-compose.yaml exec backend bash"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "express": "^5.2.1",
    "pg-promise": "^12.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
